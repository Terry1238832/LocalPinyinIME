#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE @LOCALPINYIN_VERSION_FILE_TYPE@
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "080404B0"
        BEGIN
            VALUE "CompanyName", "@LOCALPINYINIME_COMPANY_NAME@"
            VALUE "FileDescription", "@LOCALPINYIN_VERSION_FILE_DESCRIPTION@"
            VALUE "FileVersion", "@LOCALPINYIN_VERSION_NUMERIC@.0"
            VALUE "InternalName", "@LOCALPINYIN_VERSION_TARGET@"
            VALUE "LegalCopyright", "@LOCALPINYINIME_COPYRIGHT@"
            VALUE "OriginalFilename", "@LOCALPINYIN_VERSION_ORIGINAL_FILENAME@"
            VALUE "ProductName", "@LOCALPINYINIME_DISPLAY_NAME@"
            VALUE "ProductVersion", "@LOCALPINYIN_VERSION_PACKAGE@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0804, 1200
    END
END
