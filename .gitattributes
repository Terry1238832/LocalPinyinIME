* text=auto

# UTF-8 source and project metadata.
*.cpp text working-tree-encoding=UTF-8 eol=lf
*.c text working-tree-encoding=UTF-8 eol=lf
*.h text working-tree-encoding=UTF-8 eol=lf
*.hpp text working-tree-encoding=UTF-8 eol=lf
*.cmake text working-tree-encoding=UTF-8 eol=lf
CMakeLists.txt text working-tree-encoding=UTF-8 eol=lf
*.md text working-tree-encoding=UTF-8 eol=lf
*.tsv text working-tree-encoding=UTF-8 eol=lf
*.json text working-tree-encoding=UTF-8 eol=lf
*.rc text working-tree-encoding=UTF-8 eol=lf
*.def text working-tree-encoding=UTF-8 eol=lf
*.in text working-tree-encoding=UTF-8 eol=lf

# Windows automation and installer scripts.
*.ps1 text working-tree-encoding=UTF-8 eol=crlf
*.psm1 text working-tree-encoding=UTF-8 eol=crlf
*.cmd text working-tree-encoding=UTF-8 eol=crlf
*.bat text working-tree-encoding=UTF-8 eol=crlf
*.iss text working-tree-encoding=UTF-8 eol=crlf

# Generated native binaries are never source text.
*.dll binary
*.exe binary
*.pdb binary
*.lib binary
*.exp binary
*.obj binary
*.idb binary
*.ilk binary
*.ipdb binary
*.iobj binary
*.zip binary
*.7z binary
*.msi binary
*.msix binary
*.appx binary
*.sqlite binary
*.sqlite3 binary
*.db binary
